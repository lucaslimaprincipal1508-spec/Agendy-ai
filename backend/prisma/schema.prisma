generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url moved to PrismaClient
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  photo        String?
  appointments Appointment[]
}

model Appointment {
  id     String   @id @default(cuid())
  date   DateTime
  time   String
  userId String
  user   User     @relation(fields: [userId], references: [id])
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  date          DateTime
  time          String
  status        String   @default("PENDING")
}
