generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  photo        String?
  appointments Appointment[]
}

model Appointment {
  id     String   @id @default(cuid())
  date   DateTime // Aqui foi a correção: tirei o @ e deixei só o tipo
  time   String
  userId String
  user   User     @relation(fields: [userId], references: [id])
}